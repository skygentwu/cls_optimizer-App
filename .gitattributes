# 统一文本文件以 LF 换行并按 UTF-8 处理，避免跨平台（Windows GBK/CRLF）导致的乱码与整文件 diff。
* text=auto eol=lf

*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Windows 脚本保持 CRLF
*.bat  text eol=crlf

# 二进制文件不做换行转换
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.ttf  binary
*.woff binary
*.woff2 binary
